 rв†ђcon Handler payload;ns;Event;ID;Info;events;fns;fn;event;reqfn;info;sns;i;code;conn;coni;sock;z;m;msg;sessionspace;form;hr;CALLER;app;new;old;token;TID;URL;f
 вЋ•TRAPв†ђ0 'S'
 'R'Log'#',(вЌ•con),': ',payload
 iв†ђ(2вЉѓSESSIONS)вЌіcon
 :If i>в‰ў1вЉѓSESSIONS
